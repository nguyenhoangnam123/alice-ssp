# Postgres (matches docker-compose.yml)
DATABASE_URL=postgres://ssp:ssp@localhost:5432/ssp

# Cognito (stubbed in MVP1 — values used only when AUTH_MODE=cognito)
AUTH_MODE=stub
COGNITO_REGION=eu-west-1
COGNITO_USER_POOL_ID=eu-west-1_EXAMPLE
COGNITO_CLIENT_ID=EXAMPLE

# GitHub (the fleet-managers repo we open PRs into)
GITHUB_TOKEN=ghp_REPLACE
FLEET_REPO_OWNER=ORG
FLEET_REPO_NAME=fleet-managers
FLEET_REPO_BASE_BRANCH=main

# AI agent (mocked in MVP1 — values used only when AI_MODE=bedrock)
AI_MODE=mock
BEDROCK_REGION=eu-west-1
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# Workflow orchestrator (mocked in MVP1)
WORKFLOW_MODE=in-process
